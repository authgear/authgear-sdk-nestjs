{
  "entryPoints": [
    "../src/index.ts"
  ],
  "entryPointStrategy": "resolve",
  "tsconfig": "../tsconfig.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "content/api",
  "readme": "none",
  "hideGenerator": true,
  "skipErrorChecking": true,
  "groupOrder": ["Functions", "Classes", "Interfaces", "Type Aliases", "Enumerations", "*"]
}
